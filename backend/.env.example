PORT=3010

# DB
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_NAME=hotelmanager
DB_PORT=5432
JWT_SECRET=my-super-secret-key-change-in-production

# Seeding
ADMIN_EMAIL=default@mail.com # для seeding суперадмина на инициализации
ADMIN_PASSWORD=default

# URLS for services
FRONTEND_URL=url # CORS

# Storage for uploads
STORAGE_DRIVER=local
STORAGE_PUBLIC_URL_BASE=http://localhost:3010/uploads

# CDN-MIGRATION: Yandex Cloud Object Storage — заполняется при переезде (Linear «Переезд на CDN»)
